<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.wyk.mapper.UserPlayHistoryMapper">
  <resultMap id="BaseResultMap" type="com.example.wyk.model.domain.UserPlayHistory">
    <id column="id" property="id" jdbcType="INTEGER" />
    <result column="user_id" property="userId" jdbcType="INTEGER" />
    <result column="song_id" property="songId" jdbcType="INTEGER" />
    <result column="play_time" property="playTime" jdbcType="TIMESTAMP" />
  </resultMap>
  <sql id="Base_Column_List">
    id, user_id, song_id, play_time
  </sql>

  <select id="selectUserPlayHistory" resultType="java.util.HashMap">
    SELECT id,
           user_id  AS userId,
           song_id  AS songId,
           play_time AS playTime
    FROM user_play_history
    WHERE user_id = #{userId}
    ORDER BY play_time DESC
    LIMIT 50
  </select>
</mapper>
