<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.wyk.mapper.SongMapper">
  <resultMap id="BaseResultMap" type="com.example.wyk.model.domain.Song">
    <id column="id" property="id" jdbcType="INTEGER" />
    <result column="singer_id" property="singerId" jdbcType="INTEGER" />
    <result column="name" property="name" jdbcType="VARCHAR" />
    <result column="introduction" property="introduction" jdbcType="VARCHAR" />
    <result column="create_time" property="createTime" jdbcType="TIMESTAMP" />
    <result column="update_time" property="updateTime" jdbcType="TIMESTAMP" />
    <result column="pic" property="pic" jdbcType="VARCHAR" />
    <result column="url" property="url" jdbcType="VARCHAR" />
  </resultMap>
  <resultMap id="ResultMapWithBLOBs" type="com.example.wyk.model.domain.Song" extends="BaseResultMap">
    <result column="lyric" property="lyric" jdbcType="LONGVARCHAR" />
  </resultMap>
  <sql id="Base_Column_List">
    id, singer_id, name, introduction, create_time, update_time, pic
  </sql>
  <sql id="Blob_Column_List">
    lyric
  </sql>

  <!-- 按歌曲被收藏次数排行（type=0 为单曲收藏）；不查询歌词字段以减轻负载 -->
  <select id="selectSongRankByCollectCount" resultType="java.util.HashMap">
    SELECT
      s.id AS id,
      s.singer_id AS singerId,
      s.name AS name,
      s.introduction AS introduction,
      s.pic AS pic,
      s.url AS url,
      s.duration AS duration,
      IFNULL(si.name, '') AS singerName,
      t.cnt AS collectCount
    FROM (
      SELECT song_id, COUNT(*) AS cnt
      FROM collect
      WHERE type = 0
        AND song_id IS NOT NULL
      GROUP BY song_id
    ) t
    INNER JOIN song s ON s.id = t.song_id
    LEFT JOIN singer si ON s.singer_id = si.id
    ORDER BY t.cnt DESC, s.id ASC
    LIMIT 30
  </select>

</mapper>
